# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ── n8n Workflow ──────────────────────────────────────────────────────────────
WEBHOOK_URL=https://your-n8n.com/webhook/your-webhook-id
ANALYSIS_MODE=trend,category,monthly

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AI Providers (add keys for whichever you want to use) ────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini — free at aistudio.google.com → Get API key
GEMINI_API_KEY=AIza_your_gemini_api_key_here

# Mistral — free tier at console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# Cohere — free trial at dashboard.cohere.com
COHERE_API_KEY=your_cohere_api_key_here
